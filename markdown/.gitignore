# Markdown auto-generated files
# These are regenerated on each build, so don't commit them

# Auto-generated index
/index.json

# Extracted assets and markdown
/extracted/**/*.md
/extracted/**/*.png
/extracted/**/*.jpg
/extracted/**/*.jpeg
/extracted/**/*.gif
/extracted/**/*.webp
/extracted/**/*.svg

# Assets folder (populated by extraction)
/assets/**

# But DO track folder structure and empty placeholders
!/extracted/.gitkeep
!/manual/
!/manual/**/*.md
!/assets/.gitkeep
